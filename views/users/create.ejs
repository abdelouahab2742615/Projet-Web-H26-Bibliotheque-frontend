<%- include("../partials/header", { title: title }) %>
<%- include("../partials/navbar") %>

<div class="container">
  <div class="card form-card">
    <h1>Ajouter un utilisateur</h1>

    <% if (error) { %>
      <div class="alert-error"><%= error %></div>
    <% } %>

    <form action="/users/create" method="POST">
      <div class="form-group">
        <label>Username</label>
        <input type="text" name="username" value="<%= formData?.username || '' %>" required>
      </div>

      <div class="form-group">
        <label>Email</label>
        <input type="email" name="email" value="<%= formData?.email || '' %>" required>
      </div>

      <div class="form-group">
        <label>Mot de passe</label>
        <input type="password" name="password" value="<%= formData?.password || '' %>" required>
      </div>

      <div class="form-group">
        <label>Role ID</label>
        <input type="number" name="roleId" value="<%= formData?.roleId || '' %>" required>
      </div>

      <button class="btn-primary">Ajouter</button>
    </form>
  </div>
</div>

<%- include("../partials/footer") %>
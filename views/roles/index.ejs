<%- include("../partials/header", { title: title }) %>
<%- include("../partials/navbar") %>

<div class="container">
  <div class="top-bar">
    <h1>Liste des rôles</h1>
    <a href="/roles/create" class="btn-primary" style="width:auto;">Ajouter</a>
  </div>

  <% if (error) { %>
    <div class="alert-error"><%= error %></div>
  <% } %>

  <div class="card">
    <table class="users-table">
      <thead>
        <tr>
          <th>ID</th>
          <th>Nom du rôle</th>
          <th>Actions</th>
        </tr>
      </thead>
      <tbody>
        <% if (!roles || roles.length === 0) { %>
          <tr>
            <td colspan="3">Aucun rôle trouvé.</td>
          </tr>
        <% } else { %>
          <% roles.forEach(roleItem => { %>
            <tr>
              <td><%= roleItem.id %></td>
              <td><%= roleItem.name %></td>
              <td class="actions">
                <a href="/roles/edit/<%= roleItem.id %>" class="btn-edit">Modifier</a>

                <form action="/roles/delete/<%= roleItem.id %>" method="POST" style="display:inline;">
                  <button
                    type="submit"
                    class="btn-delete"
                    onclick="return confirm('Supprimer ce rôle ?')">
                    Supprimer
                  </button>
                </form>
              </td>
            </tr>
          <% }) %>
        <% } %>
      </tbody>
    </table>
  </div>
</div>

<%- include("../partials/footer") %>
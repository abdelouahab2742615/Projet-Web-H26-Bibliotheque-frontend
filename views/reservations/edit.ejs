<%- include("../partials/header", { title: title }) %>
<%- include("../partials/navbar") %>

<div class="container">
  <div class="form-card">
    <h1><%= title %></h1>

    <% if (error) { %>
      <div class="alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/reservations/edit/<%= reservation.id %>" class="form">
      <div class="form-group">
        <label for="userId">Utilisateur *</label>
        <select
          id="userId"
          name="userId"
          class="form-control"
          required>
          <option value="">Sélectionner un utilisateur</option>
          <% users.forEach(user => { %>
            <option value="<%= user.id %>" <%= reservation.userId == user.id ? 'selected' : '' %>>
              <%= user.username %> (<%= user.email %>)
            </option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="bookId">Livre *</label>
        <select
          id="bookId"
          name="bookId"
          class="form-control"
          required>
          <option value="">Sélectionner un livre</option>
          <% books.forEach(book => { %>
            <option value="<%= book.id %>" <%= reservation.bookId == book.id ? 'selected' : '' %>>
              <%= book.title %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="expiryDate">Date d'expiration *</label>
        <input
          type="date"
          id="expiryDate"
          name="expiryDate"
          class="form-control"
          value="<%= reservation.expiryDate ? reservation.expiryDate.substring(0, 10) : '' %>"
          required />
      </div>

      <div class="form-actions">
        <button type="submit" class="btn-primary">Modifier</button>
        <a href="/reservations" class="btn-secondary">Annuler</a>
      </div>
    </form>
  </div>
</div>

<%- include("../partials/footer") %>

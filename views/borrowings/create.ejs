<%- include("../partials/header", { title: title }) %>
<%- include("../partials/navbar") %>

<div class="container">
  <div class="form-card">
    <h1><%= title %></h1>

    <% if (error) { %>
      <div class="alert-error"><%= error %></div>
    <% } %>

    <form method="POST" action="/borrowings/create" class="form">
      <div class="form-group">
        <label for="userId">Utilisateur *</label>
        <select
          id="userId"
          name="userId"
          class="form-control"
          required>
          <option value="">Sélectionner un utilisateur</option>
          <% users.forEach(user => { %>
            <option value="<%= user.id %>" <%= formData.userId == user.id ? 'selected' : '' %>>
              <%= user.username %> (<%= user.email %>)
            </option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="bookId">Livre *</label>
        <select
          id="bookId"
          name="bookId"
          class="form-control"
          required>
          <option value="">Sélectionner un livre</option>
          <% books.forEach(book => { %>
            <option value="<%= book.id %>" <%= formData.bookId == book.id ? 'selected' : '' %>>
              <%= book.title %>
            </option>
          <% }) %>
        </select>
      </div>

      <div class="form-group">
        <label for="dueDate">Date d'échéance *</label>
        <input
          type="date"
          id="dueDate"
          name="dueDate"
          class="form-control"
          value="<%= formData.dueDate || '' %>"
          required />
      </div>

      <div class="form-actions">
        <button type="submit" class="btn-primary">Ajouter</button>
        <a href="/borrowings" class="btn-secondary">Annuler</a>
      </div>
    </form>
  </div>
</div>

<%- include("../partials/footer") %>
